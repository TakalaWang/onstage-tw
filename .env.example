# SQLite 資料庫路徑（預設 data/onstage.db）
ONSTAGE_DB=data/onstage.db

# 頁面讀取的快照路徑（預設 static/shows.json）
ONSTAGE_SNAPSHOT=static/shows.json

# 保護 POST /api/scrape 的權杖；cron 觸發抓取時帶 Authorization: Bearer <token>
ONSTAGE_SCRAPE_TOKEN=

# 寄送開賣通知用的 SMTP 設定（留空則 `npm run notify` 只做 dry-run 印出，不寄信）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=onstage-tw <no-reply@example.com>
