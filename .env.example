# All variables are OPTIONAL — every one has a sensible default in code, so the
# app builds, scrapes and runs with no .env at all. Copy to `.env` only to override.

# Canonical site URL — used for RSS feeds, sitemap.xml, <link rel=canonical>,
# Open Graph / Twitter tags and the per-show /event/[id] pages.
# Default: https://onstage.takalawang.dev
ONSTAGE_SITE_URL=https://onstage.takalawang.dev

# Set to 1 for a fast scrape that skips per-show detail pages (much quicker, but
# no description / notes / sessions / intro images). Leave empty for a full scrape.
# Default: full scrape
ONSTAGE_FAST=

# Where writeOutputs() writes the generated artifacts (shows.json, descriptions.json,
# feed*.xml, sitemap.xml). Default: static
ONSTAGE_OUT_DIR=static

# Path the page loaders read the show snapshot / descriptions from at build time.
# Defaults: static/shows.json and static/descriptions.json
ONSTAGE_SNAPSHOT=static/shows.json
ONSTAGE_DESCRIPTIONS=static/descriptions.json
